#!/bin/sh
set -e

dir=$(dirname -- "$0")
dir=$(cd -- "$dir" && pwd -P)

normalize() {
    [ $# -gt 0 ] || set -- -
    xsltproc "$dir/normalize.xsl" "$@"
}

if [ "x$*" != "x--test" ]; then
    normalize "$@"
    exit $?
fi

assert() {
    if [ "$2" != "$3" ]; then
        printf '%s\nexpected and actual differ:\n%s\n%s\n' "$1" "$3" "$2"
        return 1
    fi
}

assert "values are preserved (and attributes are sorted)" \
"$(printf '<a c="&amp;" b="&quot;">&amp;</a>' | normalize)" \
'<?xml version="1.0" encoding="UTF-8"?>
<a b="&quot;" c="&amp;">&amp;</a>'

assert "elements are sorted by name" \
"$(printf '<a><c/><b/><d/></a>' | normalize)" \
'<?xml version="1.0" encoding="UTF-8"?>
<a>
    <b></b>
    <c></c>
    <d></d>
</a>'

assert "elements are sorted by attribute values" \
"$(printf '<a><b n="X"/><b n="A"/><b n="O"/></a>' | normalize)" \
'<?xml version="1.0" encoding="UTF-8"?>
<a>
    <b n="A"></b>
    <b n="O"></b>
    <b n="X"></b>
</a>'

assert "elements are sorted by namespace (prefix ignored)" \
"$(printf '<a xmlns="a:a"><n:b xmlns:n="y"/><s:a xmlns:s="z"/><c/></a>' | normalize)" \
'<?xml version="1.0" encoding="UTF-8"?>
<a xmlns="a:a">
    <c></c>
    <b xmlns="y"></b>
    <a xmlns="z"></a>
</a>'

assert "attribute namespace prefixes are preserved" \
"$(printf '<a xmlns:op="ns:do">
    <b c="1" op:name="bar" op:v="" />
    <b op:name="app" c="1"/></a>' | normalize)" \
'<?xml version="1.0" encoding="UTF-8"?>
<a>
    <b xmlns:op="ns:do" op:name="app" c="1"></b>
    <b xmlns:op="ns:do" op:name="bar" op:v="" c="1"></b>
</a>'

