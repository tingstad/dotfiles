#!/bin/sh
set -e

# { rm file; command > file; } < file
# https://backreference.org/2011/01/29/in-place-editing-of-files/index.html

inplace()(
    file="$1"
    shift
    temp=$(mktemp)

    cp "$file" "$temp" #preserves permission mode bits

    "$@" < "$file" > "$temp"

    mv "$temp" "$file"
)

function mktemp() {
    tmpdir=${TMPDIR:-/tmp/}
    echo "${tmpdir%/}/inplace$$"
}

inplace "$@"

