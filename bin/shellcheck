#!/bin/bash
set -e

shellcheck() {
    local last_arg="${@:$#}"
    file=""
    if [ -e "$last_arg" ]; then
        file="$(cd "$(dirname "$last_arg")"; pwd -P)/$(basename "$last_arg")"
        set -- "${@:1:$#-1}"
    fi
    local vol_opt="$(selinuxenabled 2>/dev/null && echo ,Z)"
    docker run --rm --network none \
        ${file:+ -v "$file":/mnt/script:ro$vol_opt} \
        koalaman/shellcheck:stable \
        "$@" ${file:+script}
}

shellcheck "$@"

